# 영양상담 AI+ 환경변수 예시 파일
# 실제 값이 들어간 .env 파일은 절대 커밋하지 않습니다 (.gitignore에 이미 제외되어 있음).

# --- 프론트엔드(Vite, VITE_ 접두사만 브라우저에 노출됨) ---
VITE_APP_NAME="영양상담 AI+"
VITE_APP_BASE_URL="http://localhost:5173"

# --- Cloudflare Pages Functions(서버 측 전용, 아직 미사용) ---
# 아래 값들은 Milestone 1에서는 사용하지 않으며, 이후 단계에서 채워집니다.
# Google OAuth (Milestone 1 후속 단계에서 추가)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Gemini API Key 암호화용 마스터 키 (Milestone 6에서 추가)
# GEMINI_KEY_ENCRYPTION_SECRET=

# 사용자 연결정보 저장소 바인딩 이름 (Milestone 1 후속 단계, Cloudflare D1 등)
# CONNECTION_STORE_BINDING=
