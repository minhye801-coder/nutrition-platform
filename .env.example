# 영양상담 AI+ 환경변수 예시 파일
# 실제 값이 들어간 .env 파일은 절대 커밋하지 않습니다 (.gitignore에 이미 제외되어 있음).

# --- 프론트엔드(Vite, VITE_ 접두사만 브라우저에 노출됨) ---
VITE_APP_NAME="영양상담 AI+"
VITE_APP_BASE_URL="http://localhost:5173"

# --- Cloudflare Pages Functions(서버 측 전용) ---
# 아래 값들은 Pages Functions(functions/) 코드에서만 읽는 서버 측 비밀값입니다.
# Vite는 VITE_ 접두사가 없는 값을 클라이언트 번들에 절대 포함하지 않지만,
# 실제로 Pages Functions가 이 값을 읽는 곳은 .env가 아니라 Cloudflare의 별도
# 환경변수/시크릿 체계입니다. 자세한 설정 방법은 docs/google-oauth-setup.md 참고.
#   - 로컬 개발(wrangler pages dev): 이 파일을 참고해 .dev.vars 파일에 실제 값을 채운다.
#   - Cloudflare 운영 배포: `wrangler pages secret put <이름>` 또는 대시보드에서 등록한다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
SESSION_SECRET=

# Gemini API Key 암호화용 마스터 키 (Milestone 6에서 추가)
# GEMINI_KEY_ENCRYPTION_SECRET=

# 사용자 연결정보 저장소 바인딩 이름 (Milestone 1 후속 단계, Cloudflare D1 등)
# CONNECTION_STORE_BINDING=
